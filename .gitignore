# Borrowed Space — gitignore

# Godot imports (rebuilt on first run)
.godot/
.import/

# But these specific files DO need to be tracked
# (just in case git would otherwise exclude them via patterns).
# In Godot 4, *.uid files are stable identifiers for resource refs
# and *.import files describe imported assets; both must be committed.
!*.uid
!*.import


# Ink compiled outputs (regenerated by build)
*.json.gz
*.ink~

# Editor / OS junk
*~
.DS_Store
*.swp
*.swo

# Backup files
*.bak

# Personal notes (solo-dev side notes)
notes/
.scratch/

# Raw art source (large, scans — keep out of repo)
art-source/

# Build outputs
dist/
build/

# Logs
*.log
