{
  "_meta": {
    "purpose": "Variant generator pools per NPC archetype. Drawn per-run; same archetype can yield different variants across runs (per NPCS.md §recurring-NPC).",
    "version": "0.1-draft",
    "note": "Zero lore; identifiers + structural flags + first-line question scaffolding only. 6-8 variants per archetype per spec. Each archetype declares a first-line 'question to the captain' (NPCS.md locked) but the *text* lives in Ink, not here.",
    "schema": {
      "archetype_id": "string — fixed archetype slot (NPC1, NPC2, NPC3, NPC-T, NPC-AI)",
      "display_label": "string — placeholder label only; final naming rights Bayard's",
      "anchor_stage": "enum [early, mid, late, constant] — phase-of-encounter",
      "first_question": "string — the question this archetype asks the captain (voice-fragment, not lore)",
      "variants": "array of variant objects; pool size 6-8 per spec",
      "variant": {
        "variant_id": "string — unique within archetype (e.g., NPC1-1)",
        "passive_traits": "array of string — captain-side trait IDs that *highlight* this variant for first meeting",
        "trust_seed": "int — initial held-trust arc vector (NPCS.md §state-vector)",
        "voice_fragments": "array of string — placeholder voice-cue IDs the Ink layer reads",
        "genship_affinity": "array of string — genship IDs this variant is *familiar* with (first-meeting memo mechanics)"
      }
    }
  },
